# Application
APP_NAME=Persian Invoice Agent
APP_ENV=development
APP_BASE_URL=http://localhost:8001
DEBUG=false

# LLM / STT Gateway (OpenAI-compatible)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
WHISPER_MODEL=whisper-1
STT_TIMEOUT_SECONDS=45
STT_MAX_RETRIES=2
STT_RETRY_DELAY=1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
AUDIO_TIMEOUT_SECONDS=60

# Email Service (placeholder)
EMAIL_SERVICE_API_KEY=your_email_service_api_key_here
EMAIL_FROM_ADDRESS=invoices@example.com
EMAIL_APPROVAL_RECIPIENT=approver@example.com
MANAGER_EMAIL=your.email@example.com
DEFAULT_CLIENT_EMAIL=client@example.com

# PDF Service (placeholder)
PDF_OUTPUT_DIR=./generated_invoices
PDF_FONT_REGULAR_PATH=./app/assets/fonts/Vazirmatn-Regular.ttf
PDF_FONT_BOLD_PATH=./app/assets/fonts/Vazirmatn-Bold.ttf

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# Sister service (Persian Voice Agent)
VOICE_AGENT_URL=http://localhost:8000
VOICE_AGENT_TIMEOUT_SECONDS=5
